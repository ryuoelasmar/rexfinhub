# Azure Graph API (primary email method)
# Get these from Azure Portal > App Registrations > your app
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SENDER=relasmar@rexfin.com

# SMTP Fallback (optional - used if Azure Graph is not configured)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com

# Claude API (for on-demand prospectus analysis)
ANTHROPIC_API_KEY=

# REST API Key (protects /api/v1/ endpoints)
API_KEY=

# Session secret (random string for cookie signing)
SESSION_SECRET=

# Site authentication
SITE_PASSWORD=
ADMIN_PASSWORD=

# Feature flags
# Set to 1 to enable the Ownership (13F) pillar
ENABLE_13F=

# Daily pipeline scheduler (hour in UTC, empty = disabled)
# 22 UTC = 5 PM EST / 6 PM EDT
PIPELINE_SCHEDULE_HOUR=22

# CBOE Symbol Reservation Scanner
# Full Cookie header value for account.cboe.com. Easiest to grab via Chrome
# DevTools > Network > pick a successful symbol_status request > Headers >
# Request Headers > copy the entire `cookie:` value. Multiple cookies separated
# by `; ` are fine. Refresh manually when the scan starts failing
# (cboe_scan_runs.status = 'failed' with auth error).
CBOE_SESSION_COOKIE=
# Concurrency to use for the async scan. Run scripts/probe_cboe_rate_limit.py
# once and set this to the suggested value (~85% of CBOE's tolerance ceiling).
# Leave empty to fall back to the conservative default of 10.
CBOE_CONCURRENCY=
