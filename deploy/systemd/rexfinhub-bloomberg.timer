[Unit]
Description=REX FinHub Bloomberg Pull Timer (every 15 min, 4-6 PM ET weekdays)

[Timer]
# 4-6 PM Eastern = 20:00-22:00 UTC
OnCalendar=Mon..Fri 20:00 UTC
OnCalendar=Mon..Fri 20:15 UTC
OnCalendar=Mon..Fri 20:30 UTC
OnCalendar=Mon..Fri 20:45 UTC
OnCalendar=Mon..Fri 21:00 UTC
OnCalendar=Mon..Fri 21:15 UTC
OnCalendar=Mon..Fri 21:30 UTC
OnCalendar=Mon..Fri 21:45 UTC
Persistent=true

[Install]
WantedBy=timers.target
